<ruleset name="HyvaThemes">
    <description>Hyvä-Themes Coding Standard</description>

    <!-- File extensions to be checked. -->
    <arg name="extensions" value="php,phtml,xml"/>

    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/playwright-report/*</exclude-pattern>

    <rule name="HyvaThemes.Templates.BlockEscapeInTemplate">
        <include-pattern>*\.phtml$</include-pattern>
    </rule>

    <rule name="HyvaThemes.Templates.IfInTemplate">
        <include-pattern>*\.phtml$</include-pattern>
    </rule>

    <rule name="HyvaThemes.Templates.CspRegisterInlineScript">
        <include-pattern>*\.phtml$</include-pattern>
    </rule>

    <rule name="HyvaThemes.Annotation.InheritsMethodAnnotation">
        <include-pattern>*\.php$</include-pattern>
    </rule>

    <rule name="HyvaThemes.PHPCompatibility.SetTestVersion">
        <include-pattern>*\.php$</include-pattern>
        <include-pattern>*\.phtml$</include-pattern>
    </rule>

    <rule ref="Magento2">
        <exclude name="Magento2.Annotation"/>
        <exclude name="Magento2.Commenting.ClassPropertyPHPDocFormatting"/>
        <exclude name="Squiz.CSS.NamedColours"/>
        <exclude name="Magento2.Less"/>
        <exclude name="Magento2.GraphQL"/>

        <!-- temporarily -->
        <exclude name="Magento2.Templates.ThisInTemplate.FoundThis"/>
    </rule>

    <rule ref="Generic.ControlStructures.InlineControlStructure">
        <exclude-pattern>*\.phtml$</exclude-pattern>
    </rule>

    <rule ref="Generic.WhiteSpace.ScopeIndent">
        <properties>
            <property name="ignoreIndentationTokens" type="array">
                <element value="T_COMMENT"/>
                <element value="T_DOC_COMMENT_OPEN_TAG"/>
                <element value="T_OPEN_TAG"/>
                <element value="T_OPEN_TAG_WITH_ECHO"/>
                <element value="T_CLOSE_TAG"/>
            </property>
        </properties>
    </rule>

    <rule name="Squiz.ControlStructures.ControlSignature.SpaceAfterCloseParenthesis">
        <severity>8</severity>
    </rule>

    <rule ref="Generic.Files.LineLength">
        <exclude-pattern>*.xml</exclude-pattern>
        <properties>
            <property name="lineLimit" value="200" />
            <property name="absoluteLineLimit" value="800" />
            <property name="ignoreComments" value="true" />
        </properties>
    </rule>

</ruleset>
