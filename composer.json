{
    "name": "ecoplan/hyva-coding-standard",
    "description": "A set of Hyvä specific PHP CodeSniffer rules extending the Magento Coding Standard",
    "license": "OSL-3.0",
    "require": {
        "php": ">=8.0",
        "magento/magento-coding-standard": ">=25.0",
        "squizlabs/php_codesniffer": "^3.6.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "HyvaThemes\\": "src/HyvaThemes/"
        }
    },
    "scripts": {
        "post-install-cmd": "php bin/configure-phpcs-paths.php",
        "post-update-cmd": "php bin/configure-phpcs-paths.php"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
